import rpy2.robjects as ro
from rpy2.robjects.packages import importr, data
from rpy2.robjects import pandas2ri

# pandas変換有効化
pandas2ri.activate()

# Rパッケージ読み込み
ro.r('library(airway)')
ro.r('library(SummarizedExperiment)')  # assay用（重要）

# データロード
